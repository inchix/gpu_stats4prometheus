{
  "uid": "gpu-stats4prometheus",
  "title": "GPU Stats (gpu_stats4prometheus)",
  "tags": [
    "nvidia",
    "gpu",
    "gpu_stats4prometheus"
  ],
  "timezone": "browser",
  "refresh": "15s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "gpu",
        "type": "query",
        "datasource": {
          "uid": "${DS_PROMETHEUS}"
        },
        "query": "label_values(gpu_stats_gpu_info, gpu_uuid)",
        "includeAll": true,
        "multi": true,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "refresh": 1
      }
    ]
  },
  "panels": [
    {
      "id": 100,
      "title": "GPUs Detected",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "count(gpu_stats_gpu_info)",
          "legendFormat": "GPUs"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      }
    },
    {
      "id": 101,
      "title": "Avg GPU Temp",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 5,
        "x": 4,
        "y": 0
      },
      "datasource": {
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "avg(gpu_stats_temperature_celsius{gpu_uuid=~\"$gpu\", sensor=\"gpu\"})",
          "legendFormat": "Avg"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 65
              },
              {
                "color": "red",
                "value": 80
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "value"
      }
    },
    {
      "id": 102,
      "title": "Avg GPU Utilization",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 5,
        "x": 9,
        "y": 0
      },
      "datasource": {
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "avg(gpu_stats_utilization_ratio{gpu_uuid=~\"$gpu\", type=\"gpu\"})",
          "legendFormat": "Avg"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.7
              },
              {
                "color": "red",
                "value": 0.9
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "value"
      }
    },
    {
      "id": 103,
      "title": "Total Power Draw",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 5,
        "x": 14,
        "y": 0
      },
      "datasource": {
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "sum(gpu_stats_power_draw_watts{gpu_uuid=~\"$gpu\"})",
          "legendFormat": "Total"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
